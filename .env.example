# KIE / GPT Image 2
KIE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Public webhook base URL for KIE callbacks. Use your ngrok HTTPS URL for local dev.
NEXT_PUBLIC_SITE_URL=

# Upstash Redis (recommended)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Marketplace KV/Redis alternative. Used only when UPSTASH_REDIS_REST_* is absent.
KV_REST_API_URL=
KV_REST_API_TOKEN=
